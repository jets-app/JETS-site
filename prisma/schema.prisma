generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  PARENT
  ADMIN
  PRINCIPAL
  SECRETARY
  REVIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  OFFICE_REVIEW
  PRINCIPAL_REVIEW
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  ACCEPTED
  DOCUMENTS_PENDING
  SCHOLARSHIP_REVIEW
  ENROLLED
  REJECTED
  WAITLISTED
  WITHDRAWN
}

enum RecommendationStatus {
  PENDING
  SENT
  VIEWED
  COMPLETED
  EXPIRED
}

enum DocumentTemplateType {
  MEDICAL_FORM
  STUDENT_HANDBOOK
  TUITION_CONTRACT
  ENROLLMENT_AGREEMENT
  SCHOLARSHIP_CONTRACT
  PHOTO_RELEASE
  CUSTOM
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_SIGNED
  COMPLETED
  EXPIRED
  VOIDED
}

enum DocumentRecipientType {
  PARENT
  STUDENT
}

enum ReviewDecision {
  PENDING
  APPROVED
  NEEDS_INFO
  REJECTED
}

enum PaymentType {
  APPLICATION_FEE
  TUITION
  REGISTRATION_FEE
  DONATION
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ScholarshipStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
}

enum InterviewStatus {
  PENDING
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum ApplicationType {
  NEW
  REAPPLICATION
}

enum DonationFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum PaymentMethodType {
  CREDIT_CARD
  BANK_ACCOUNT
}

// ==================== AUTH (NextAuth) ====================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String
  role          Role       @default(PARENT)
  status        UserStatus @default(PENDING_VERIFICATION)
  phone         String?
  avatarUrl     String?
  // Bumped via "Sign out all sessions" — JWTs with a stale version get
  // rejected by the auth.ts jwt callback on next request.
  sessionVersion Int       @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts Account[]
  sessions Session[]

  applications            Application[]
  sentMessages            Message[]              @relation("SentMessages")
  receivedMessages        Message[]              @relation("ReceivedMessages")
  reviews                 ApplicationReview[]
  notes                   ApplicationNote[]
  paymentMethods          PaymentMethod[]
  autoPaySettings         AutoPaySettings?
  assignedInterviews      Application[]          @relation("InterviewPrincipal")
  interviewAvailability   InterviewAvailability[]
  loginEvents             LoginEvent[]
  auditLogs               AuditLog[]
  emailChangeRequests     EmailChangeRequest[]

  // TOTP-based 2FA. Optional for all staff today; can be required-for-admins
  // later by gating sign-in on totpEnabled when role === ADMIN.
  totpSecret              String?    // base32-encoded shared secret
  totpEnabled             Boolean    @default(false)
  totpBackupCodes         String[]   // bcrypt-hashed one-time backup codes

  // Stripe Customer ID for tuition + saved payment methods. Created on demand
  // the first time the parent saves a card or pays an invoice through Stripe.
  stripeCustomerId        String?    @unique

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// Tracks pending and recently-completed email change requests so we can:
//   1. Block the change until the NEW address clicks "confirm"
//   2. Let the OLD address click "revert" within 24h of confirmation
// in case the change was malicious (account takeover scenario).
model EmailChangeRequest {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldEmail     String
  newEmail     String
  confirmToken String    @unique
  confirmedAt  DateTime?
  revertToken  String    @unique
  revertedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ==================== APPLICATION ====================

model Application {
  id              String            @id @default(cuid())
  referenceNumber String            @unique
  status          ApplicationStatus @default(DRAFT)
  type            ApplicationType   @default(NEW)
  academicYear    String

  parentId String
  parent   User   @relation(fields: [parentId], references: [id])

  student Student?

  applicationFeePaid   Boolean @default(false)
  applicationFeeAmount Int     @default(50000)
  discountCode         String?
  discountAmount       Int     @default(0)

  // Tuition pricing — set per student. Defaults to JETS' standard $39,500
  // total. The "scholarship" is a discount the office applies before the
  // contract is signed; net = tuitionTotalCents - tuitionScholarshipCents.
  tuitionTotalCents       Int  @default(3950000)
  tuitionScholarshipCents Int  @default(0)
  // Optional admin override for the deposit (defaults to 10% of net).
  tuitionDepositCents     Int?
  // Optional admin override for installment count (defaults to 9 = Sept-May).
  tuitionInstallmentCount Int?

  // Payment plan chosen by parent at contract signing.
  //   MONTHLY_10        — 10% deposit + 9 monthly installments (Sept-May)
  //   ONE_SHOT_NOW      — 100% on contract day
  //   ONE_SHOT_DEFERRED — 10% deposit + 90% on Sept 1
  tuitionPaymentPlan  String?
  // When the plan was locked in (i.e. contract signed). Cron skips when set.
  tuitionPlanLockedAt DateTime?

  currentStep   Int @default(1)
  completionPct Int @default(0)

  // Form data as JSON for flexibility
  hebrewNames         Json?
  fatherInfo          Json?
  motherInfo          Json?
  guardianInfo        Json?
  emergencyContact    Json?
  siblings            Json?
  grandparents        Json?
  schoolHistory       Json?
  parentQuestions     Json?
  applicantAssessment Json?
  studiesInfo         Json?
  tradePreferences    Json?
  extracurricular     Json?
  additionalQuestions Json?
  essay               String? @db.Text

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  archivedAt DateTime?

  interviewStatus        InterviewStatus @default(PENDING)
  interviewDate          DateTime?
  interviewEndsAt        DateTime?
  interviewNotes         String?         @db.Text
  interviewPrincipalId   String?
  interviewPrincipal     User?           @relation("InterviewPrincipal", fields: [interviewPrincipalId], references: [id])
  interviewZoomMeetingId String?
  interviewZoomJoinUrl   String?
  interviewZoomStartUrl  String?
  interviewZoomPasscode  String?

  interviewReminder24hSentAt   DateTime?
  interviewReminder1hSentAt    DateTime?
  interviewScheduleNudgeSentAt DateTime?

  documents       Document[]
  recommendations Recommendation[]
  reviews         ApplicationReview[]
  payments        Payment[]
  notes           ApplicationNote[]
  scholarship     ScholarshipApplication?

  @@index([parentId])
  @@index([status])
  @@index([academicYear])
}

// ==================== STUDENT ====================

model Student {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  firstName     String
  lastName      String
  middleName    String?
  preferredName String?
  dateOfBirth   DateTime
  gender        String?
  photoUrl      String?
  email         String?
  phone         String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String? @default("United States")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alumni Alumni?
}

// ==================== RECOMMENDATIONS ====================

model Recommendation {
  id            String               @id @default(cuid())
  applicationId String
  application   Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  refereeName     String
  refereeEmail    String
  refereePhone    String?
  refereeRelation String

  token  String               @unique @default(cuid())
  status RecommendationStatus @default(PENDING)

  // Confidential - not visible to parents
  responses   Json?
  submittedAt DateTime?

  sentAt    DateTime  @default(now())
  viewedAt  DateTime?
  expiresAt DateTime

  @@index([applicationId])
  @@index([token])
}

// ==================== DOCUMENTS & E-SIGNING ====================

model DocumentTemplate {
  id          String               @id @default(cuid())
  name        String
  type        DocumentTemplateType
  content     Json
  htmlContent String?              @db.Text
  isActive    Boolean              @default(true)
  version     Int                  @default(1)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  documents Document[]
}

model Document {
  id            String               @id @default(cuid())
  applicationId String
  application   Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  templateId    String?
  template      DocumentTemplate?    @relation(fields: [templateId], references: [id])

  title         String
  status        DocumentStatus       @default(DRAFT)
  recipientType DocumentRecipientType @default(PARENT)

  content        Json?
  customizedHtml String? @db.Text

  signatureUrl String?
  signedAt     DateTime?
  signerName   String?
  signerIp     String?

  token     String    @unique @default(cuid())
  sentAt    DateTime?
  viewedAt  DateTime?
  expiresAt DateTime?

  pdfUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([token])
  @@index([status])
}

// ==================== APPLICATION REVIEW ====================

model ApplicationReview {
  id            String         @id @default(cuid())
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User           @relation(fields: [reviewerId], references: [id])

  department String
  decision   ReviewDecision @default(PENDING)
  comments   String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([reviewerId])
}

model ApplicationNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  content       String      @db.Text
  isInternal    Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

// ==================== PAYMENTS & BILLING ====================

model Payment {
  id            String        @id @default(cuid())
  applicationId String?
  application   Application?  @relation(fields: [applicationId], references: [id])

  type        PaymentType
  status      PaymentStatus @default(PENDING)
  amount      Int
  currency    String        @default("usd")
  description String?

  stripePaymentIntentId   String? @unique
  stripeCheckoutSessionId String?
  stripeReceiptUrl        String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([applicationId])
  @@index([stripePaymentIntentId])
}

model Invoice {
  id            String  @id @default(cuid())
  invoiceNumber String  @unique
  applicationId String?
  parentId      String

  lineItems  Json
  subtotal   Int
  tax        Int    @default(0)
  total      Int
  amountPaid Int    @default(0)

  status  String   @default("draft")
  dueDate DateTime
  paidAt  DateTime?

  processingFee     Int     @default(0)
  paymentMethodType String?

  stripeInvoiceId String? @unique
  pdfUrl          String?

  // Late fee — single $50 fee applied once per invoice when 10+ days past due.
  // The fee is added to `total` and recorded as a line item; `lateFeeAppliedAt`
  // gates the cron so we don't apply it twice.
  lateFeeAppliedAt DateTime?

  // Refund tracking for invoices that were paid then refunded. We keep the
  // original paid stamps as audit trail and record the refund here.
  refundedAt       DateTime?
  refundedAmount   Int       @default(0)
  refundReason     String?

  // Wire payment — set when parent indicates they've sent a wire. Cleared by
  // admin when they reconcile the wire (which marks the invoice paid).
  wirePendingAt    DateTime?
  wireReference    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([status])
}

model PaymentMethod {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  PaymentMethodType
  last4                 String
  brand                 String?
  expiryMonth           Int?
  expiryYear            Int?
  bankName              String?
  accountNickname       String?
  isDefault             Boolean           @default(false)
  stripePaymentMethodId String?           @unique
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([userId])
}

model AutoPaySettings {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled         Boolean   @default(true)
  paymentMethodId String?
  lastChargedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DiscountCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  amountOff   Int?
  percentOff  Int?
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

// ==================== TUITION AFFORDABILITY ====================

model TuitionAssessment {
  id            String @id @default(cuid())
  applicationId String @unique

  fatherIncome      Json?
  motherIncome      Json?
  totalAnnualIncome Int?

  assets      Json?
  totalAssets Int?

  liabilities      Json?
  totalLiabilities Int?

  monthlyExpenses      Json?
  totalMonthlyExpenses Int?

  householdSize            Int?
  childrenInTuitionSchools Int?

  taxReturnUrls Json?

  recommendedContribution Int?
  calculationDetails      Json?

  adminAdjustedAmount Int?
  adminNotes          String? @db.Text
  factsRecommendation Int?
  reviewedAt          DateTime?
  reviewedBy          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== SCHOLARSHIPS ====================

model ScholarshipApplication {
  id            String            @id @default(cuid())
  applicationId String            @unique
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  financialInfo    Json?
  essayResponse    String?         @db.Text
  requestedAmount  Int?
  affordableAmount Int?
  approvedAmount   Int?
  status           ScholarshipStatus @default(SUBMITTED)
  reviewNotes      String?         @db.Text

  taxReturnUrls Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== MESSAGING ====================

model Message {
  id         String  @id @default(cuid())
  senderId   String
  sender     User    @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String?
  receiver   User?   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  subject String
  body    String  @db.Text
  isRead  Boolean @default(false)

  isBulk    Boolean @default(false)
  bulkGroup String?

  emailSent Boolean @default(false)
  smsSent   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([receiverId, isRead])
  @@index([senderId])
}

model MessageTemplate {
  id      String @id @default(cuid())
  name    String
  subject String
  body    String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== ALUMNI ====================

model Alumni {
  id        String   @id @default(cuid())
  studentId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id])

  firstName        String
  lastName         String
  photoUrl         String?
  email            String?
  phone            String?
  address          String?
  graduationYear   Int
  programCompleted String?
  notes            String? @db.Text

  // Enhanced alumni fields
  currentRole     String?
  currentCompany  String?
  city            String?
  state           String?
  linkedinUrl     String?
  isFeatured      Boolean  @default(false)
  lastContactedAt DateTime?
  engagementScore Int      @default(0)

  mentorProfile MentorProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([graduationYear])
}

// ==================== JOB BOARD ====================

enum JobStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum JobType {
  FULL_TIME
  PART_TIME
  APPRENTICESHIP
  INTERNSHIP
  CONTRACT
  VOLUNTEER
}

model JobPosting {
  id          String    @id @default(cuid())
  title       String
  company     String
  description String    @db.Text
  location    String?
  type        JobType   @default(FULL_TIME)
  trade       String?
  salary      String?
  contactEmail String?
  contactPhone String?
  applyUrl    String?
  status      JobStatus @default(ACTIVE)

  postedById  String?

  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([trade])
}

// ==================== MENTORSHIP ====================

enum MentorshipStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model MentorProfile {
  id          String   @id @default(cuid())
  alumniId    String   @unique
  alumni      Alumni   @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  trades      String[]
  bio         String?  @db.Text
  maxMentees  Int      @default(2)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MentorshipMatch {
  id          String           @id @default(cuid())
  mentorId    String
  menteeName  String
  menteeEmail String?
  menteePhone String?
  trade       String?
  status      MentorshipStatus @default(PENDING)
  notes       String?          @db.Text
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([mentorId])
  @@index([status])
}

// ==================== ALUMNI EVENTS ====================

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RsvpStatus {
  INVITED
  ATTENDING
  DECLINED
  MAYBE
}

model AlumniEvent {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  location    String?
  date        DateTime
  endDate     DateTime?
  status      EventStatus @default(DRAFT)
  maxAttendees Int?
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  rsvps EventRsvp[]

  @@index([date])
  @@index([status])
}

model EventRsvp {
  id        String      @id @default(cuid())
  eventId   String
  event     AlumniEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  alumniId  String?
  name      String
  email     String?
  status    RsvpStatus  @default(INVITED)
  createdAt DateTime    @default(now())

  @@unique([eventId, email])
  @@index([eventId])
}

// ==================== DONORS ====================

model Donor {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  country   String?  @default("United States")
  notes     String?  @db.Text
  tags      String[]

  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations Donation[]
  receipts  DonorReceipt[]

  @@index([lastName, firstName])
}

model Donation {
  id      String @id @default(cuid())
  donorId String
  donor   Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)

  amount    Int
  currency  String          @default("usd")
  frequency DonationFrequency @default(ONE_TIME)
  method    String?
  campaign  String?
  purpose   String?
  notes     String?

  stripePaymentIntentId String? @unique
  stripeSubscriptionId  String?

  receiptSent Boolean @default(false)
  receiptId   String?

  donatedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([donorId])
  @@index([campaign])
  @@index([donatedAt])
}

model DonorReceipt {
  id      String @id @default(cuid())
  donorId String
  donor   Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)

  type      String
  year      Int?
  amount    Int
  pdfUrl    String?
  emailSent Boolean  @default(false)
  sentAt    DateTime?

  createdAt DateTime @default(now())

  @@index([donorId])
}

model DonorLetterTemplate {
  id      String @id @default(cuid())
  name    String
  type    String
  subject String
  body    String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== NOTIFICATIONS ====================

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model NotificationTemplate {
  id        String             @id @default(cuid())
  name      String             @unique
  trigger   String
  channel   NotificationChannel @default(EMAIL)
  subject   String
  body      String             @db.Text
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model NotificationLog {
  id            String             @id @default(cuid())
  templateName  String?
  channel       NotificationChannel @default(EMAIL)
  recipientEmail String?
  recipientPhone String?
  recipientName  String?
  subject       String
  body          String             @db.Text
  status        NotificationStatus @default(QUEUED)
  errorMessage  String?
  applicationId String?
  metadata      Json?
  sentAt        DateTime?
  createdAt     DateTime           @default(now())

  @@index([applicationId])
  @@index([status])
  @@index([createdAt])
}

// ==================== INQUIRIES / LEADS ====================

enum InquiryStatus {
  NEW
  CONTACTED
  TOUR_SCHEDULED
  TOUR_COMPLETED
  CONVERTED
  CLOSED
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String?       @db.Text
  source    String        @default("contact_form")
  status    InquiryStatus @default(NEW)

  studentAge    Int?
  interestedIn  String?
  preferredDate DateTime?

  referredBy     String?
  referralSource String?

  notes      String?  @db.Text
  assignedTo String?
  followUpAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ==================== SYSTEM SETTINGS ====================

model SystemSettings {
  id String @id @default("settings")

  currentAcademicYear    String   @default("2026-2027")
  openSchoolYears        String[] @default(["2026-2027"])
  applicationFeeAmount   Int      @default(50000)
  applicationsOpen       Boolean  @default(true)

  schoolName      String @default("JETS School")
  schoolLegalName String @default("JETS Synagogue")
  schoolEin       String @default("68-0500418")
  schoolAddress   String @default("Granada Hills, Los Angeles, CA")
  schoolPhone     String @default("(818) 831-3000")
  schoolEmail     String @default("info@jetsschool.org")

  stripeConnected     Boolean @default(false)
  quickbooksConnected Boolean @default(false)
  calendlyUrl         String?

  // QuickBooks Online OAuth tokens & settings
  qbAccessToken      String?   @db.Text
  qbRefreshToken     String?   @db.Text
  qbRealmId          String?
  qbTokenExpiresAt   DateTime?
  qbCompanyName      String?
  qbLastSyncAt       DateTime?
  qbAutoSyncInvoices Boolean   @default(true)
  qbAutoSyncPayments Boolean   @default(true)
  qbAutoSyncCustomers Boolean  @default(true)

  // Wire transfer instructions — shown to parents/donors who choose to pay by
  // wire. Stored here so the office can update bank info without a code deploy.
  wireBankName       String?
  wireAccountName    String?
  wireRoutingNumber  String?
  wireAccountNumber  String?
  wireSwiftCode      String?
  wireBankAddress    String?
  wireInstructions   String? @db.Text

  updatedAt DateTime @updatedAt
}

// ==================== QUICKBOOKS SYNC ====================

model QuickBooksSync {
  id         String    @id @default(cuid())
  entityType String
  entityId   String
  qbId       String?
  status     String    @default("pending")
  errorMsg   String?
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([status])
}

// ==================== LOGIN EVENTS ====================
// Every successful sign-in is logged here. We email the user the first time we
// see a new (userAgentHash, ipPrefix) pair so account compromise gets noticed.
model LoginEvent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgentHash String   // sha256 of the User-Agent string
  ipPrefix      String?  // first 3 octets only — we don't store full IPs
  userAgentRaw  String?  // last 200 chars for the email body
  notified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, userAgentHash])
}

// ==================== AUDIT LOG ====================
// Append-only record of every meaningful admin/staff action. Never deleted.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Restrict)
  action     String   // e.g. "application.status.changed", "discount.code.deleted"
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipPrefix   String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}

// ==================== INTERVIEW AVAILABILITY ====================
// Weekly recurring availability for principals (one row per day-of-week window).
// Minutes are from midnight in the configured timezone (default America/Los_Angeles).
model InterviewAvailability {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startMinutes Int
  endMinutes   Int
  timezone     String   @default("America/Los_Angeles")
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([dayOfWeek])
}
